# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://sdr_user:sdr_pass@localhost:5432/ai_sdr_db

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production-make-it-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── AI Provider Keys ──────────────────────────────────────────────────────────
# The backend uses a multi-provider fallback chain:
#   Gemini → Groq → OpenRouter → OpenAI → Mock AI (always available)
#
# You only need ONE key to use real AI. Leave unused keys empty or as "mock".
# If ALL keys are empty/mock, the built-in Mock AI Simulator activates automatically.

# Google Gemini 1.5 Flash — Primary provider (recommended, free tier available)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Groq — Secondary provider (very fast, free tier available)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# OpenRouter — Tertiary provider (access to Claude, Mistral, etc.)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# OpenAI — Quaternary provider (GPT-4o-mini)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here
